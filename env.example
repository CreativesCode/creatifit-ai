# Core
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI — SOLO en el servidor (Supabase Edge Function), NUNCA con prefijo NEXT_PUBLIC_.
# No pongas la key en .env.local del frontend; se configura como secret de la función:
#   supabase secrets set OPENAI_API_KEY=sk-... MODEL_NAME=gpt-4o-mini
# (estas dos lineas son referencia para el deploy, no para el build del cliente)

# Database — choose ONE
## Supabase (recommended for MVP)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

## Neon (alternative)
# DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# Auth (only if using NextAuth instead of Supabase Auth)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=...

# Push (optional)
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# RevenueCat (compras dentro de la app / suscripciones).
# Las API keys del SDK son PÚBLICAS (van en el cliente): es seguro exponerlas.
# En desarrollo basta la key de la Test Store (test_...). En produccion usa la
# key especifica de cada plataforma desde el dashboard de RevenueCat.
NEXT_PUBLIC_REVENUECAT_TEST_KEY=test_WPKEAaPUgcUEXsEiUtsdHfTgSBp
NEXT_PUBLIC_REVENUECAT_IOS_KEY=
NEXT_PUBLIC_REVENUECAT_ANDROID_KEY=
# Identificadores de producto (identifier de tienda en RevenueCat, no el prod... interno)
NEXT_PUBLIC_REVENUECAT_PRODUCT_MONTHLY=subscription_monthly
NEXT_PUBLIC_REVENUECAT_PRODUCT_ANNUAL=subscription_yearly
